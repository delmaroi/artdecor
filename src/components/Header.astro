---
import { Icon } from "astro-icon/components";

const currentPath = Astro.url.pathname;
const nav = [
  { href: "/", label: "Strona główna" },
  { href: "/o-nas/", label: "O nas" },
  { href: "/kontakt/", label: "Kontakt" },
];
---
<div class="header-wrapper">
  <header class="header" id="site-header">
    <div class="header-inner">
      <a href="/" class="logo" aria-label="Art Decor – strona główna">
        <img src="/images/logo_kolor2.svg" alt="Art Decor Logo" class="logo-img" />
      </a>
      <nav class="nav" aria-label="Główne menu">
        <ul class="nav-list">
          {nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={["nav-link", { "nav-link--active": currentPath === item.href || (item.href === "/" && currentPath === "/") }]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <div class="header-actions">
        <a href="tel:+48696293362" class="header-cta">
          <Icon name="lucide:phone" size={18} />
          696 293 362
        </a>
        <a href="https://www.facebook.com/artdecorreklama/" target="_blank" rel="noopener noreferrer" class="header-facebook" aria-label="Nasz Facebook">
          <Icon name="mdi:facebook" size={18} />
        </a>
      </div>
      <button type="button" class="menu-toggle" aria-label="Otwórz menu" aria-expanded="false">
        <span class="menu-toggle-bar"></span>
        <span class="menu-toggle-bar"></span>
        <span class="menu-toggle-bar"></span>
      </button>
    </div>
  </header>
</div>

<style>
  .header-wrapper {
    position: fixed;
    top: 30px;
    left: 0;
    right: 0;
    z-index: 1000;
    display: flex;
    justify-content: center;
    padding-inline: 1.5rem;
    pointer-events: none;
  }

  .header {
    pointer-events: auto;
    background: var(--structa-charcoal);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    transition: all var(--transition-base);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    width: 100%;
    max-width: var(--container);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 12px 32px;
  }

  .logo {
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-base);
    padding: 0;
    margin-right: 1.5rem;
    width: 140px; /* Stała szerokość dla balansu */
    height: 56px; /* Stała wysokość kontenera */
    overflow: hidden;
    border-radius: 8px;
    background: transparent;
  }

  .logo-img {
    height: 96px; /* Obrazek jest znacznie większy niż kontener */
    width: auto;
    object-fit: contain;
    transform: translateY(4px); /* Przesunięcie, aby wycentrować treść (wycięcie marginesów SVG) */
    transition: transform var(--transition-base);
  }

  .logo:hover .logo-img {
    transform: translateY(4px) scale(1.05);
  }

  @media (max-width: 767px) {
    .header {
      width: 100%;
      max-width: none;
    }
    .header-inner {
      justify-content: space-between;
      padding: 4px 16px;
      gap: 0.5rem;
    }
    .logo {
      margin-right: 0.5rem;
      width: 150px;
      height: 64px;
    }
    .logo-img {
      height: 120px;
      transform: translateY(2px);
    }
  }

  .nav-list {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
  }

  @media (min-width: 768px) {
    .nav-list {
      display: flex;
    }
  }

  .nav-link {
    padding: 0.6rem 1.25rem;
    color: rgba(255, 255, 255, 0.6);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.8125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: all var(--transition-base);
    border-radius: 100px;
  }

  .nav-link:hover {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.08);
  }

  .nav-link--active {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.12);
  }

  .header-actions {
    display: none;
    align-items: center;
    gap: 0.5rem;
    margin-left: 0.5rem;
  }

  @media (min-width: 768px) {
    .header-actions {
      display: flex;
    }
  }

  .header-cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 0.8125rem;
    color: #ffffff;
    padding: 0.6rem 1.5rem;
    border-radius: 100px;
    background: var(--structa-accent);
    transition: all var(--transition-base);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .header-cta:hover {
    transform: translateY(-2px);
    background: var(--structa-accent-hover);
    box-shadow: 0 8px 16px rgba(255, 92, 53, 0.3);
  }

  .header-facebook {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 50%;
    color: white;
    transition: all var(--transition-base);
  }

  .header-facebook:hover {
    background: rgba(255, 255, 255, 0.15);
    transform: translateY(-2px);
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 2.5rem;
    height: 2.5rem;
    background: rgba(255, 255, 255, 0.08);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    color: #ffffff;
    padding: 0 10px;
  }

  @media (max-width: 767px) {
    .menu-toggle {
      display: flex;
      align-items: center;
    }
  }

  .menu-toggle-bar {
    display: block;
    width: 20px;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    transition: all var(--transition-base);
  }


  .menu-toggle[aria-expanded="true"] .menu-toggle-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle[aria-expanded="true"] .menu-toggle-bar:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle[aria-expanded="true"] .menu-toggle-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 767px) {
    .menu-toggle {
      display: flex;
    }

    .nav {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      margin-top: 0.5rem;
      background: var(--structa-charcoal);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: var(--radius-lg);
      padding: 1rem;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      transition: all var(--transition-base);
      box-shadow: var(--shadow-lg);
    }

    .nav--open {
      max-height: 400px;
      opacity: 1;
    }

    .nav-list {
      flex-direction: column;
      display: flex;
      gap: 0.5rem;
    }

    .nav-link {
      display: block;
      padding: 0.75rem 1rem;
      border-radius: var(--radius-sm);
    }
  }
</style>

<script>
  const toggle = document.querySelector(".menu-toggle");
  const nav = document.querySelector(".nav");
  if (toggle && nav) {
    toggle.addEventListener("click", () => {
      const open = nav.classList.toggle("nav--open");
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "Zamknij menu" : "Otwórz menu");
    });
  }
</script>
