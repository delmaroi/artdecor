---
import { Icon } from "astro-icon/components";
import type { Service } from "../types/index";

const services: Service[] = [
  { title: "Pylony / totemy", slug: "pylony-totemy", icon: "lucide:layout-grid" },
  { title: "Kasetony z dibondu", slug: "kasetony-z-dibondu", icon: "lucide:package" },
  { title: "Litery blokowe", slug: "litery-blokowe", icon: "lucide:type" },
  { title: "Szyldy szklane", slug: "szyldy-szklane", icon: "lucide:square" },
  { title: "Litery przestrzenne", slug: "litery-przestrzenne", icon: "lucide:box" },
  { title: "Oklejanie witryn", slug: "oklejanie-witryn", icon: "lucide:rectangle-horizontal" },
  { title: "Oklejanie samochodów", slug: "oklejanie-samochodow", icon: "lucide:car" },
  { title: "Systemy wystawiennicze", slug: "systemy-wystawiennicze", icon: "lucide:layout-grid" },
  { title: "Wycinanie znaków", slug: "wycinanie-znakow", icon: "lucide:scissors" },
  { title: "Tablice LED", slug: "tablice-led", icon: "lucide:lightbulb" },
  { title: "Punkty gastronomiczne", slug: "punkty-gastronomiczne", icon: "lucide:utensils-crossed" },
  { title: "Piaskowanie artystyczne", slug: "piaskowanie-artystyczne", icon: "lucide:sparkles" },
];
---
<section class="section services" id="uslugi">
  <div class="container">
    <div class="section-header">
      <div class="section-badge fade-in stagger-1">NASZE USŁUGI</div>
      <h2 class="section-title fade-in stagger-2">Co robimy <span class="accent-text">najlepiej</span></h2>
      <p class="section-lead fade-in stagger-3">Od koncepcji po montaż – dostarczamy kompletne systemy identyfikacji wizualnej dla Twojego biznesu.</p>
    </div>

    <div class="services-bento fade-in stagger-4">
      {services.map((service, index) => (
        <a href={`/uslugi/${service.slug}/`} class={`bento-item bento-item--${index % 5}`}>
          <div class="bento-content">
            <div class="bento-icon">
              <Icon name={service.icon} size={28} />
            </div>
            <div class="bento-text">
              <h3 class="bento-title">{service.title}</h3>
              <p class="bento-desc">Profesjonalna realizacja i montaż systemów reklamowych.</p>
            </div>
          </div>
          <div class="bento-footer">
            <span class="bento-link">Dowiedz się więcej</span>
            <div class="bento-plus">
              <Icon name="lucide:plus" size={20} />
            </div>
          </div>
          <div class="bento-bg"></div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .section-header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .section-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--structa-accent);
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    margin: 0 0 1.5rem;
    color: var(--structa-black);
    letter-spacing: -0.02em;
  }

  .accent-text {
    color: var(--structa-accent);
  }

  .section-lead {
    color: var(--structa-gray-text);
    max-width: 600px;
    margin: 0 auto;
    font-size: 1.125rem;
    line-height: 1.6;
  }

  .services-bento {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .services-bento {
      grid-template-columns: repeat(6, 1fr);
      grid-auto-rows: 280px;
      gap: 1.5rem;
    }

    .bento-item--0 { grid-column: span 3; grid-row: span 1; } /* Large horizontal */
    .bento-item--1 { grid-column: span 3; grid-row: span 1; }
    .bento-item--2 { grid-column: span 2; grid-row: span 1; } /* Square */
    .bento-item--3 { grid-column: span 4; grid-row: span 1; } /* Wide */
    .bento-item--4 { grid-column: span 6; grid-row: span 1; } /* Full width teaser style */
  }

  .bento-item {
    position: relative;
    background: var(--structa-charcoal);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: var(--radius-xl);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-decoration: none;
    overflow: hidden;
    transition: all var(--transition-base);
    box-shadow: var(--shadow);
  }

  .bento-item:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-color: rgba(255, 92, 53, 0.2);
  }

  .bento-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, rgba(255, 92, 53, 0.05), transparent 70%);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .bento-item:hover .bento-bg {
    opacity: 1;
  }

  .bento-content {
    position: relative;
    z-index: 2;
  }

  .bento-icon {
    width: 3.5rem;
    height: 3.5rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--structa-white);
    margin-bottom: 1.5rem;
    transition: all var(--transition-base);
  }

  .bento-item:hover .bento-icon {
    background: var(--structa-white);
    color: var(--structa-black);
    transform: scale(1.05) rotate(-5deg);
  }

  .bento-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--structa-white);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .bento-desc {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.5;
    opacity: 0.8;
  }

  .bento-footer {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 2rem;
  }

  .bento-link {
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--structa-white);
    opacity: 0;
    transform: translateX(-10px);
    transition: all var(--transition-base);
  }

  .bento-item:hover .bento-link {
    opacity: 1;
    transform: translateX(0);
  }

  .bento-plus {
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--structa-white);
    transition: all var(--transition-base);
  }

  .bento-item:hover .bento-plus {
    background: var(--structa-accent);
    color: var(--structa-white);
    border-color: var(--structa-accent);
    transform: rotate(90deg);
  }
</style>

