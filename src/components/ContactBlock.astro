---
import { Icon } from "astro-icon/components";

const phone = "696 293 362";
const emails = [
  { label: "Biuro", address: "biuro@artdecor.net.pl" },
  { label: "Dział Graficzny", address: "grafika@artdecor.net.pl" },
  { label: "Produkcja", address: "reklama@artdecor.net.pl" }
];
const companyName = "F.H.U. Art Decor";
const street = "Męczenników Oświęcimskich 16";
const city = "43-200 Pszczyna";
const hours = [
  { days: "Poniedziałek–piątek", time: "8:00 – 17:00" },
  { days: "Sobota", time: "nieczynne" },
  { days: "Niedziela", time: "nieczynne" },
];
---
<section class="section contact-block pt-4" id="kontakt">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-card glass-card">
        <div class="contact-info">
          <h3 class="contact-heading">Dane kontaktowe</h3>
          <address class="contact-address">
            <div class="contact-item">
              <Icon name="lucide:map-pin" class="contact-icon" size={24} />
              <div>
                <strong>Siedziba firmy</strong>
                <p>{companyName}<br />{street}<br />{city}</p>
              </div>
            </div>
            <div class="contact-item">
              <Icon name="lucide:phone" class="contact-icon" size={24} />
              <div>
                <strong>Obsługa klienta</strong>
                <p><a href={`tel:+48${phone.replace(/\s/g, "")}`}>{phone}</a></p>
              </div>
            </div>
            <div class="contact-item">
              <Icon name="lucide:mail" class="contact-icon" size={24} />
              <div class="emails-list">
                {emails.map(e => (
                  <div class="email-row">
                    <strong>{e.label}:</strong>
                    <a href={`mailto:${e.address}`}>{e.address}</a>
                  </div>
                ))}
              </div>
            </div>
          </address>
        </div>
      </div>
      <div class="contact-card glass-card">
        <div class="contact-hours">
          <h3 class="contact-heading">Godziny pracy</h3>
          <ul class="hours-list">
            {hours.map((h) => (
              <li>
                <span class="hours-days">{h.days}</span>
                <span class="hours-time">{h.time}</span>
              </li>
            ))}
          </ul>
          <a href="https://www.facebook.com/artdecorreklama/" target="_blank" rel="noopener noreferrer" class="contact-social">
            <Icon name="mdi:facebook" size={24} />
            Odwiedź nasz Facebooku
          </a>
        </div>
      </div>
    </div>
  </div>
  
  <div class="map-container">
    <iframe 
      src="https://maps.google.com/maps?q=Art%20Decor%20M%C4%99czennik%C3%B3w%20O%C5%9Bwi%C4%99cimskich%2016,%2043-200%20Pszczyna&t=&z=15&ie=UTF8&iwloc=&output=embed" 
      width="100%" 
      height="450" 
      style="border:0;" 
      allowfullscreen="" 
      loading="lazy" 
      referrerpolicy="no-referrer-when-downgrade">
    </iframe>
  </div>
</section>

<style>
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    margin: 0 0 1rem;
    color: var(--color-text);
  }

  .section-lead {
    color: var(--color-text-muted);
    max-width: 600px;
    margin: 0 auto;
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .contact-grid {
    display: grid;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-card {
    padding: 2rem;
    transition: all var(--transition-base);
  }

  .contact-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(254, 107, 0, 0.1);
    border-color: var(--color-accent);
  }

  .contact-heading {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 1.5rem;
    color: var(--color-text);
  }

  .contact-address {
    font-style: normal;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .contact-icon {
    flex-shrink: 0;
    color: var(--color-accent);
    margin-top: 0.25rem;
  }

  .contact-item strong {
    display: block;
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .contact-item p {
    margin: 0;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .contact-item a:hover {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .emails-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .email-row {
    display: flex;
    flex-direction: column;
  }

  .email-row strong {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.1rem;
  }

  .map-container {
    margin-top: 4rem;
    width: 100%;
    border-radius: var(--radius-2xl);
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
  }

  .map-container iframe {
    display: block;
    width: 100%;
  }

  .hours-list {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
  }

  .hours-list li {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--glass-border);
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .hours-list li:last-child {
    border-bottom: none;
  }

  .hours-days {
    flex-shrink: 0;
    font-weight: 500;
  }

  .hours-time {
    color: var(--color-text);
    font-weight: 600;
  }

  .contact-social {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.75rem;
    background: rgba(254, 107, 0, 0.08);
    border: 1px solid rgba(254, 107, 0, 0.15);
    border-radius: var(--radius-xl);
    color: var(--color-accent);
    font-weight: 700;
    transition: all var(--transition-base);
  }

  .contact-social:hover {
    background: rgba(254, 107, 0, 0.12);
    border-color: var(--color-accent);
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(254, 107, 0, 0.2);
  }
</style>
