---
const logos = Array.from({ length: 10 }, (_, i) => `/images/klienci/${i + 1}.png`);
---
<section class="section clients" id="klienci">
  <div class="container">
    <div class="section-header">
      <div class="section-badge fade-in stagger-1">NASI ZAUFANI PARTNERZY</div>
      <h2 class="section-title fade-in stagger-2">Zaufali <span class="accent-text">nam</span></h2>
    </div>

    <div class="clients-grid fade-in stagger-3">
      {logos.map((logo, i) => (
        <div class="client-card">
          <div class="client-logo-wrapper">
            <img src={logo} alt={`Logo klienta ${i + 1}`} class="client-logo" loading="lazy" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .clients-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .clients-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .client-card {
    background: var(--structa-white);
    border: 1px solid var(--structa-border);
    border-radius: var(--radius-lg);
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-base);
    cursor: pointer;
  }

  .client-card:hover {
    background: var(--structa-white);
    border-color: var(--structa-black);
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
  }

  .client-logo-wrapper {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
    opacity: 0.6;
    transition: all var(--transition-base);
    transform: scale(0.95);
  }

  .client-card:hover .client-logo-wrapper {
    opacity: 1;
    filter: grayscale(0) brightness(1);
    transform: scale(1.05);
  }

  .client-logo {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
</style>
