---
import { Icon } from "astro-icon/components";
---

<div id="cookie-consent" class="cookie-consent hidden">
  <div class="cookie-content glass-card">
    <div class="cookie-icon-wrap">
      <Icon name="lucide:circle-dot" class="cookie-icon" />
    </div>
    <div class="cookie-text-area">
      <h5 class="cookie-title">Dbamy o Twoją prywatność</h5>
      <p class="cookie-description">
        Nasza strona korzysta z plików cookies, aby zapewnić Ci najlepsze doświadczenia, analizować ruch i personalizować treści. Więcej informacji znajdziesz w naszej <a href="/polityka-prywatnosci/">Polityce Prywatności</a>.
      </p>
    </div>
    <div class="cookie-actions">
      <button id="accept-cookies" class="btn btn-primary btn-sm">Akceptuję wszystko</button>
      <button id="decline-cookies" class="btn btn-outline btn-sm">Tylko niezbędne</button>
    </div>
  </div>
</div>

<script>
  function initCookieConsent() {
    const consent = localStorage.getItem('cookie-consent');
    const banner = document.getElementById('cookie-consent');
    const acceptBtn = document.getElementById('accept-cookies');
    const declineBtn = document.getElementById('decline-cookies');

    if (!consent && banner) {
      // Pokaż baner z lekkim opóźnieniem
      setTimeout(() => {
        banner.classList.remove('hidden');
        banner.classList.add('animate-in');
      }, 1500);
    }

    const handleConsent = (choice: string) => {
      localStorage.setItem('cookie-consent', choice);
      if (banner) {
        banner.classList.add('animate-out');
        setTimeout(() => {
          banner.classList.add('hidden');
        }, 500);
      }
    };

    acceptBtn?.addEventListener('click', () => handleConsent('accepted'));
    declineBtn?.addEventListener('click', () => handleConsent('declined'));
  }

  // Inicjalizacja przy ładowaniu strony
  initCookieConsent();

  // Inicjalizacja przy przejściach stron (dla Astro View Transitions)
  document.addEventListener('astro:after-swap', initCookieConsent);
</script>

<style>
  .cookie-consent {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 10000;
    width: 100%;
    max-width: 420px;
    padding: 0 1rem;
    pointer-events: none;
  }

  .cookie-consent.hidden {
    display: none;
  }

  .cookie-content {
    background: rgba(35, 45, 72, 0.95);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    pointer-events: all;
  }

  .cookie-icon-wrap {
    width: 40px;
    height: 40px;
    background: rgba(254, 107, 0, 0.1);
    color: var(--structa-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .cookie-icon {
    width: 24px;
    height: 24px;
  }

  .cookie-title {
    color: #fff;
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    font-family: var(--font-display);
  }

  .cookie-description {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0;
  }

  .cookie-description a {
    color: var(--structa-accent);
    text-decoration: underline;
  }

  .cookie-actions {
    display: flex;
    gap: 0.75rem;
  }

  .btn-sm {
    padding: 0.6rem 1.25rem;
    font-size: 0.8125rem;
    flex: 1;
  }

  /* Animacje */
  .animate-in {
    animation: cookieIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .animate-out {
    animation: cookieOut 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes cookieIn {
    from {
      opacity: 0;
      transform: translateY(30px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes cookieOut {
    from {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
    to {
      opacity: 0;
      transform: translateY(20px) scale(0.95);
    }
  }

  @media (max-width: 639px) {
    .cookie-consent {
      bottom: 1rem;
      right: 0;
      left: 0;
      max-width: none;
    }
    
    .cookie-content {
      border-radius: var(--radius-lg);
    }
  }
</style>
