---
import { Icon } from "astro-icon/components";
---

<section class="section faq-section" id="faq">
  <div class="container">
    <div class="faq-section-header">
      <div class="section-badge">Pytania i odpowiedzi</div>
      <h2 class="section-title">Często zadawane <span class="gradient-text">pytania</span></h2>
      <p class="section-lead">Masz wątpliwości? Przygotowaliśmy odpowiedzi na najczęstsze pytania naszych klientów.</p>
    </div>

    <div class="faq-list">
      {[
        {
          q: "Ile czasu trwa realizacja zamówienia?",
          a: "Standardowy czas realizacji zamówienia wynosi od 5 do 14 dni roboczych. Termin zależy od stopnia złożoności produktu — proste szyldy wykonujemy szybciej, natomiast rozbudowane pylony czy litery blokowe LED wymagają precyzyjnej obróbki i testów. Dokładny czas podajemy zawsze przy akceptacji wyceny."
        },
        {
          q: "Czy przygotowujecie projekty graficzne?",
          a: "Tak, oferujemy kompleksową obsługę „od A do Z”. Nasz zespół projektowy przygotuje dla Ciebie wizualizację reklamy na budynku lub pojeździe, dobierze odpowiednie technologie i materiały. Możemy również zrealizować zlecenie na podstawie Twoich gotowych projektów."
        },
        {
          q: "Z jakich materiałów wykonujecie reklamy?",
          a: "Stosujemy wyłącznie materiały sprawdzonych producentów. Wykorzystujemy płyty kompozytowe Dibond/Tubond, profile aluminiowe, plexi opal oraz certyfikowane moduły LED o stopniu ochrony IP65. Dzięki temu nasze reklamy są odporne na trudne warunki atmosferyczne i zachowują estetykę przez lata."
        },
        {
          q: "Czy oferujecie montaż gotowej reklamy?",
          a: "Tak, posiadamy własną, doświadczoną ekipę montażową oraz profesjonalne zaplecze sprzętowe. Montujemy reklamy na terenie Pszczyny oraz całego województwa śląskiego (m.in. Tychy, Bielsko-Biała, Katowice). Dbamy o bezpieczne mocowanie i poprawne podłączenie instalacji elektrycznej."
        },
        {
          q: "Czy reklamy LED są energooszczędne?",
          a: "Zdecydowanie tak. Wykorzystujemy wyłącznie nowoczesną technologię LED, która zużywa minimalną ilość energii przy zachowaniu maksymalnej jasności. Dodatkowo montujemy inteligentne sterowniki i czujniki zmierzchowe, które automatycznie włączają reklamę po zmroku, co pozwala na optymalizację kosztów eksploatacji."
        }
      ].map((item, index) => (
        <div class="faq-item glass-card" data-reveal data-reveal-dir="up" data-reveal-delay={index * 0.1}>
          <button class="faq-question" aria-expanded="false">
            <span>{item.q}</span>
            <Icon name="lucide:chevron-down" size={24} class="faq-icon" />
          </button>
          <div class="faq-answer">
            <div class="faq-answer-content">
              <p>{item.a}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  function initFAQ() {
    const faqItems = document.querySelectorAll('.faq-list .faq-item');

    faqItems.forEach(item => {
      const button = item.querySelector('.faq-question');

      button.addEventListener('click', () => {
        const isExpanded = button.getAttribute('aria-expanded') === 'true';

        // Close all other items (optional, but cleaner)
        faqItems.forEach(otherItem => {
          if (otherItem !== item) {
            otherItem.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
            otherItem.querySelector('.faq-answer').style.maxHeight = null;
          }
        });

        // Toggle current item
        button.setAttribute('aria-expanded', !isExpanded);
        const answer = item.querySelector('.faq-answer');

        if (!isExpanded) {
          answer.style.maxHeight = answer.scrollHeight + "px";
        } else {
          answer.style.maxHeight = null;
        }
      });
    });
  }

  // Init on load
  document.addEventListener('DOMContentLoaded', initFAQ);
  // Init on view transitions
  document.addEventListener('astro:after-swap', initFAQ);
</script>

<style>
  .faq-section {
    padding-block: 6rem;
    background: linear-gradient(to bottom, transparent, rgba(254, 107, 0, 0.02), transparent);
  }

  .faq-section-header {
    text-align: center;
    margin-bottom: 3rem;
    max-width: 42rem;
    margin-inline: auto;
  }

  .faq-section-header .section-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--structa-accent);
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .faq-section-header .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    margin: 0 0 1.5rem;
    color: var(--structa-black);
    letter-spacing: -0.02em;
    line-height: 1.15;
  }

  .faq-section-header .section-lead {
    color: var(--structa-gray-text);
    max-width: 36rem;
    margin: 0 auto;
    font-size: 1.125rem;
    line-height: 1.6;
  }

  .faq-list {
    margin-top: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    border: 1px solid var(--glass-border);
    transition: all var(--transition-base);
    overflow: hidden;
  }

  .faq-item:hover {
    border-color: rgba(254, 107, 0, 0.3);
    box-shadow: 0 8px 32px rgba(254, 107, 0, 0.05);
  }

  .faq-question {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    background: none;
    border: none;
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    text-align: left;
    cursor: pointer;
    gap: 1.5rem;
  }

  .faq-icon {
    color: var(--color-accent);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    flex-shrink: 0;
  }

  .faq-question[aria-expanded="true"] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq-answer-content {
    padding: 0 2rem 1.5rem;
  }

  .faq-answer p {
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: 0;
  }

  @media (max-width: 640px) {
    .faq-question {
      padding: 1.25rem;
      font-size: 1rem;
    }

    .faq-answer-content {
      padding: 0 1.25rem 1.25rem;
    }
  }
</style>
