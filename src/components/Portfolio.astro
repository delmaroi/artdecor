---
import { Icon } from "astro-icon/components";
import type { PortfolioItem } from "../types/index";

const categories = [
  "Wszystko",
  "Kasetony z dibondu",
  "Litery blokowe",
  "Litery przestrzenne",
  "Oklejanie samochodów",
  "Oklejanie witryn",
  "Piaskowanie artystyczne",
  "Punkty gastronomiczne",
  "Systemy wystawiennicze",
  "Szyldy szklane",
];

const portfolioItems: PortfolioItem[] = [
  // Pylony
  { id: 1, title: "Pylon reklamowy - Kancelarie", category: "Kasetony z dibondu", image: "/images/portfolio/pylony-totemy/pylon-1.jpg" },
  { id: 2, title: "Totem reklamowy LED", category: "Kasetony z dibondu", image: "/images/portfolio/pylony-totemy/pylon-2.jpg" },
  { id: 3, title: "Nowoczesny pylon firmowy", category: "Kasetony z dibondu", image: "/images/portfolio/pylony-totemy/pylon-3.jpg" },

  // Kasetony
  { id: 4, title: "Kaseton z dibondu frezowany", category: "Kasetony z dibondu", image: "/images/portfolio/kasetony-z-dibondu/kaseton-1.jpg" },
  { id: 5, title: "Szyld świetlny LED", category: "Kasetony z dibondu", image: "/images/portfolio/kasetony-z-dibondu/kaseton-2.jpg" },
  { id: 6, title: "Kaseton reklamowy - Pracownia Fryzur", category: "Kasetony z dibondu", image: "/images/portfolio/kasetony-z-dibondu/kaseton-3.jpg" },

  // Litery Blokowe
  { id: 7, title: "Litery blokowe podświetlane", category: "Litery blokowe", image: "/images/portfolio/litery-blokowe/litera-1.jpg" },
  { id: 8, title: "Napis LED przestrzenny", category: "Litery blokowe", image: "/images/portfolio/litery-blokowe/litera-2.jpg" },
  { id: 9, title: "Logo firmowe na elewacji", category: "Litery blokowe", image: "/images/portfolio/litery-blokowe/litera-3.jpg" },

  // Witryny
  { id: 10, title: "Oklejanie witryny sklepowej", category: "Oklejanie witryn", image: "/images/portfolio/oklejanie-witryn/witryna-1.jpg" },
  { id: 11, title: "Grafika na szkle - biuro", category: "Oklejanie witryn", image: "/images/portfolio/oklejanie-witryn/witryna-2.jpg" },
  { id: 12, title: "Folia szroniona na witrynie", category: "Oklejanie witryn", image: "/images/portfolio/oklejanie-witryn/witryna-3.jpg" },

  // Samochody
  { id: 13, title: "Reklama na samochodzie dostawczym", category: "Oklejanie samochodów", image: "/images/portfolio/oklejanie-samochodow/auto-1.jpg" },
  { id: 14, title: "Oklejanie busa firmowego", category: "Oklejanie samochodów", image: "/images/portfolio/oklejanie-samochodow/auto-2.jpg" },
  { id: 15, title: "Grafika reklamowa na pojazd", category: "Oklejanie samochodów", image: "/images/portfolio/oklejanie-samochodow/auto-3.jpg" },
];
---
<section class="section portfolio" id="portfolio">
  <div class="container">
    <div class="section-header">
      <div class="section-badge fade-in stagger-1">PORTFOLIO</div>
      <h2 class="section-title fade-in stagger-2">Nasze ostatnie <span class="accent-text">realizacje</span></h2>
      <p class="section-lead fade-in stagger-3">Zobacz, jak pomagamy naszym klientom wyróżnić się na tle konkurencji.</p>
    </div>

    <div class="portfolio-filters fade-in stagger-4">
      {categories.map((cat, index) => (
        <button
          type="button"
          class="filter-btn"
          data-filter={cat === "Wszystko" ? "all" : cat.toLowerCase().replace(/\s+/g, "-")}
          aria-pressed={index === 0 ? "true" : "false"}
        >
          {cat}
        </button>
      ))}
    </div>

    <ul class="portfolio-grid fade-in stagger-4">
      {portfolioItems.map((item, index) => (
        <li class="portfolio-item" data-category={item.category.toLowerCase().replace(/\s+/g, "-")}>
          <div class="portfolio-card">
            <div class="portfolio-image-wrapper">
              <img src={item.image} alt={item.title} loading="lazy" />
              <div class="portfolio-overlay">
                <div class="portfolio-content">
                  <p class="portfolio-category">{item.category}</p>
                  <h3 class="portfolio-title">{item.title}</h3>
                  <div class="portfolio-view">
                    <span>Zobacz projekt</span>
                    <Icon name="lucide:arrow-up-right" size={20} />
                  </div>
                </div>
              </div>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .portfolio-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 4rem;
    justify-content: center;
    padding: 0.5rem;
    background: var(--structa-white);
    border: 1px solid var(--structa-border);
    border-radius: 100px;
    width: fit-content;
    margin-inline: auto;
  }

  .filter-btn {
    padding: 0.6rem 1.25rem;
    background: transparent;
    border: none;
    border-radius: 100px;
    color: var(--structa-gray-text);
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .filter-btn:hover {
    color: var(--structa-black);
    background: var(--structa-offwhite);
  }

  .filter-btn[aria-pressed="true"] {
    background: var(--structa-black);
    color: var(--structa-white);
  }

  .portfolio-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .portfolio-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .portfolio-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .portfolio-item {
    transition: all var(--transition-base);
  }

  .portfolio-card {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--structa-charcoal);
    aspect-ratio: 1 / 1;
  }

  .portfolio-image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .portfolio-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .portfolio-card:hover img {
    transform: scale(1.1);
  }

  .portfolio-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(255, 92, 53, 0.9) 0%, transparent 100%);
    display: flex;
    align-items: flex-end;
    padding: 2.5rem;
    opacity: 0;
    transition: all var(--transition-base);
  }

  .portfolio-card:hover .portfolio-overlay {
    opacity: 1;
    visibility: visible;
  }

  .portfolio-content {
    transform: translateY(20px);
    transition: all var(--transition-base);
    width: 100%;
  }

  .portfolio-card:hover .portfolio-content {
    transform: translateY(0);
  }

  .portfolio-category {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--structa-accent);
    margin-bottom: 0.5rem;
  }

  .portfolio-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--structa-white);
    margin: 0 0 1.5rem;
    line-height: 1.2;
  }

  .portfolio-view {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--structa-white);
    font-size: 0.8125rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .portfolio-view span {
    border-bottom: 2px solid var(--structa-accent);
    padding-bottom: 2px;
  }
</style>


<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const portfolioItems = document.querySelectorAll('.portfolio-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');

      // Update active state
      filterBtns.forEach(b => b.setAttribute('aria-pressed', 'false'));
      btn.setAttribute('aria-pressed', 'true');

      // Filter items
      portfolioItems.forEach(item => {
        const category = item.getAttribute('data-category');
        if (filter === 'all' || category === filter) {
          item.style.display = '';
        } else {
          item.style.display = 'none';
        }
      });
    });
  });
</script>
