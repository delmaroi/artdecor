---
import { Icon } from "astro-icon/components";

const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container">
    <div class="footer-bento">
      <div class="f-item f-item--brand">
        <div class="f-brand">
          <img src="/images/logo_kolor2.svg" alt="Art Decor Logo" class="f-logo" />
          <p class="f-desc">Tworzymy wizualną jakość, która buduje wizerunek Twojej firmy od 1996 roku.</p>
        </div>
        <div class="f-socials">
          <a href="https://www.facebook.com/artdecorreklama/" target="_blank" rel="noopener noreferrer" class="f-social-link">
            <Icon name="mdi:facebook" size={24} />
          </a>
          <a href="#" class="f-social-link">
            <Icon name="mdi:instagram" size={24} />
          </a>
        </div>
      </div>

      <div class="f-item f-item--links">
        <h4 class="f-title">Nawigacja</h4>
        <nav class="f-nav">
          <a href="/">Strona główna</a>
          <a href="/o-nas/">O nas</a>
          <a href="/oferta/">Oferta</a>
          <a href="/realizacje/">Realizacje</a>
          <a href="/kontakt/">Kontakt</a>
        </nav>
      </div>

      <div class="f-item f-item--contact">
        <h4 class="f-title">Kontakt</h4>
        <div class="f-contact-details">
          <a href="tel:+48696293362" class="f-contact-item">
            <Icon name="lucide:phone" size={18} />
            <span>+48 696 293 362</span>
          </a>
          <a href="mailto:biuro@artdecor.pl" class="f-contact-item">
            <Icon name="lucide:mail" size={18} />
            <span>biuro@artdecor.pl</span>
          </a>
          <div class="f-contact-item">
            <Icon name="lucide:map-pin" size={18} />
            <span>ul. Chopina 15, 43-200 Pszczyna</span>
          </div>
        </div>
      </div>

      <div class="f-item f-item--newsletter">
        <h4 class="f-title">Zostańmy w kontakcie</h4>
        <p class="f-desc">Zapisz się, aby otrzymywać informacje o naszych najnowszych realizacjach i technologiach.</p>
        <div class="f-newsletter-form">
          <input type="email" placeholder="Twój e-mail" class="f-input" />
          <button class="f-btn">
            <Icon name="lucide:send" size={18} />
          </button>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© {year} Art Decor. Wszystkie prawa zastrzeżone.</p>
      <div class="f-bottom-links">
        <a href="/polityka-prywatnosci/">Polityka prywatności</a>
        <a href="/cookies/">Cookies</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--structa-charcoal);
    color: var(--structa-white);
    padding-top: 4rem;
    padding-bottom: 3rem;
    border-radius: 0;
    margin-top: 4rem;
  }

  .footer-bento {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem 1.5rem;
    margin-bottom: 4rem;
  }

  .f-item--brand, .f-item--newsletter {
    grid-column: span 2;
  }

  @media (min-width: 768px) {
    .footer {
      padding-top: 6rem;
    }
    .footer-bento {
      grid-template-columns: repeat(12, 1fr);
    }
    .f-item--brand { grid-column: span 5; }
    .f-item--links { grid-column: span 2; }
    .f-item--contact { grid-column: span 5; }
    .f-item--newsletter { grid-column: span 12; margin-top: 2rem; border-top: 1px solid rgba(255, 255, 255, 0.1); padding-top: 3rem; }
  }

  @media (min-width: 1024px) {
    .f-item--brand { grid-column: span 4; }
    .f-item--links { grid-column: span 2; }
    .f-item--contact { grid-column: span 3; }
    .f-item--newsletter { grid-column: span 3; margin-top: 0; border-top: none; padding-top: 0; }
  }

  .f-item {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .f-logo {
    height: 124px;
    width: auto;
    margin-bottom: 1.5rem;
  }

  .f-desc {
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.9375rem;
    line-height: 1.6;
    max-width: 320px;
  }

  .f-socials {
    display: flex;
    gap: 1rem;
  }

  .f-social-link {
    width: 3rem;
    height: 3rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--structa-white);
    transition: all var(--transition-base);
  }

  .f-social-link:hover {
    background: var(--structa-accent);
    transform: translateY(-4px);
  }

  .f-title {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .f-nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .f-nav a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: all var(--transition-base);
  }

  .f-nav a:hover {
    color: var(--structa-accent);
    transform: translateX(5px);
  }

  .f-contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .f-contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-size: 0.9375rem;
    transition: all var(--transition-base);
  }

  a.f-contact-item:hover {
    color: var(--structa-white);
  }

  .f-newsletter-form {
    display: flex;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.5rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .f-input {
    background: transparent;
    border: none;
    padding: 0.5rem 1rem;
    color: var(--structa-white);
    font-family: inherit;
    font-size: 0.875rem;
    flex: 1;
    outline: none;
  }

  .f-btn {
    width: 2.5rem;
    height: 2.5rem;
    background: var(--structa-accent);
    border: none;
    border-radius: 50%;
    color: var(--structa-white);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all var(--transition-base);
  }

  .f-btn:hover {
    background: var(--structa-accent-hover);
    transform: scale(1.1);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: center;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.8125rem;
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .f-bottom-links {
    display: flex;
    gap: 2rem;
  }

  .f-bottom-links a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition-base);
  }

  .f-bottom-links a:hover {
    color: var(--structa-white);
  }
</style>

</style>
