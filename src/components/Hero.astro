---
import { Icon } from "astro-icon/components";
import GradientTitle from "./GradientTitle.astro";
import HeroCanvas from "./HeroCanvas.astro";

export interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
}

const { title, subtitle = "Kompleksowa reklama wizualna – pylony, totemy, kasetony z dibondu, szyldy, oklejanie witryn i samochodów.", ctaText = "Skontaktuj się", ctaHref = "/kontakt/" } = Astro.props;
---
<section class="hero">
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-image-layer"></div>
    <HeroCanvas />
    <div class="hero-overlay-gradient"></div>
    <div class="hero-noise noise-overlay"></div>
  </div>

  <div class="container hero-inner">
    <div class="hero-content">
      <h1 class="hero-title">
        {title}
      </h1>

      {subtitle && (
        <p class="hero-subtitle">
          {subtitle}
        </p>
      )}

      <div class="hero-actions">
        {ctaText && ctaHref && (
          <a href={ctaHref} class="btn btn-primary">
            {ctaText}
          </a>
        )}
        <a href="/realizacje/" class="btn btn-secondary">
          Zobacz realizacje
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-block: 8rem 4rem;
    overflow: hidden;
    background: var(--structa-charcoal);
    color: var(--structa-white);
    text-align: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-image-layer {
    position: absolute;
    inset: 0;
    background-image: url('/images/hero-bg.png');
    background-size: cover;
    background-position: center;
    filter: brightness(0.35) contrast(1.1);
    z-index: 1;
  }

  .hero-overlay-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(35, 45, 72, 0.3) 0%, rgba(35, 45, 72, 0.75) 100%);
    z-index: 3;
  }

  .hero-noise {
    opacity: 0.1;
    z-index: 3;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-content {

    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 1rem;
    background: rgba(0, 0, 0, 0.05);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--structa-gray-text);
    margin-bottom: 2rem;
  }

  .pulse-dot {
    width: 6px;
    height: 6px;
    background-color: var(--structa-accent);
    border-radius: 50%;
    position: relative;
  }

  .pulse-dot::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    background-color: var(--structa-accent);
    opacity: 0.4;
    animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  @keyframes ping {
    75%, 100% {
      transform: scale(2.5);
      opacity: 0;
    }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 700;
    line-height: 1.05;
    margin: 0 0 1.5rem;
    color: var(--structa-white);
    letter-spacing: -0.04em;
    text-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.85);
    max-width: 1000px;
    margin: 0 auto 3rem;
    line-height: 1.6;
    justify-content: flex-start;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.4);
  }

  @media (max-width: 767px) {
    .hero {
      min-height: auto;
      padding-block: 8.5rem 2rem;
    }
    .hero-title {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }
    .hero-subtitle {
      font-size: 1rem;
      margin-bottom: 2rem;
    }
  }

  .hero-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 100px;
    transition: all var(--transition-base);
    text-decoration: none;
  }

  .btn-primary {
    background: var(--structa-accent);
    color: white;
    box-shadow: 0 4px 15px rgba(255, 92, 53, 0.2);
  }

  .btn-primary:hover {
    background: var(--structa-accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(255, 92, 53, 0.3);
    color: white;
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.1);
    color: var(--structa-white);
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
    color: var(--structa-white);
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 767px) {
    .btn {
      width: 100%;
    }
  }
</style>
