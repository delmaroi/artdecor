---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import ContactBlock from "../components/ContactBlock.astro";
import "../styles/globals.css";
---
<Layout title="Kontakt – Art Decor Pszczyna | 696 293 362" description="Kontakt Art Decor Pszczyna – Męczenników Oświęcimskich 16, 43-200 Pszczyna. Tel. 696 293 362, biuro@artdecor.net.pl. Godziny: pn–pt 8:00–17:00.">
  <Header />
  <main>
    <Hero
      title="Skontaktuj się z nami"
      subtitle="Telefon, e-mail lub wizyta w Pszczynie – chętnie omówimy Twoją reklamę wizualną. Godziny pracy: poniedziałek–piątek 8:00–17:00."
      ctaText="Dane kontaktowe i mapa"
      ctaHref="#kontakt"
    />
    <ContactBlock />
  </main>
  <Footer />
</Layout>
