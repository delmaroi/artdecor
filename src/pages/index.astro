---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
import Portfolio from "../components/Portfolio.astro";
import Clients from "../components/Clients.astro";
import FAQ from "../components/FAQ.astro";
import ContactBlock from "../components/ContactBlock.astro";
import { DEFAULT_OG_BASIC_TITLE } from "../lib/seo-constants";
import "../styles/globals.css";
---
<Layout
  title="Art Decor Pszczyna – reklama wizualna | pylony, totemy, kasetony z dibondu, cięcie ploterowe"
  ogBasicTitle={DEFAULT_OG_BASIC_TITLE}
  description="Art Decor Pszczyna – agencja reklamowa i kompleksowa reklama wizualna: pylony i totemy, kasetony z dibondu (LED), litery przestrzenne i blokowe, szyldy szklane, oklejanie witryn i samochodów, tablice LED, ploter CNC, cięcie ploterowe folii. Pszczyna i region. Tel. 696 293 362."
  keywords="Art Decor Pszczyna, reklama wizualna Pszczyna, agencja reklamowa Pszczyna, pylony reklamowe, totemy, kasetony z dibondu, litery przestrzenne LED, litery blokowe, szyldy szklane, oklejanie witryn, oklejanie samochodów, cięcie ploterowe, ploter CNC, frezowanie dibond, druk wielkoformatowy, tablice LED, wycinanie znaków z folii, piaskowanie artystyczne, Śląsk"
>
  <Header />
  <main>
    <Hero
      title="Reklama wizualna z charakterem"
      subtitle="Jesteśmy agencją reklamową z Pszczyny. Kompleksowa obsługa firm i klientów indywidualnych – pylony, totemy, kasetony z dibondu, szyldy, oklejanie witryn i samochodów. Nowoczesny wzornictwo i profesjonalny park maszynowy."
      ctaText="Skontaktuj się"
      ctaHref="/kontakt/"
    />
    <Services />
    <Portfolio />
    <Clients />
    <FAQ />
    <ContactBlock />
  </main>
  <Footer />
</Layout>
